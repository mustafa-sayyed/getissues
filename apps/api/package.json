{
  "name": "@getissues/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.{js,ts,json}\""
  },
  "dependencies": {
    "@packages/db": "workspace:*",
    "better-auth": "^1.6.14",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^20.19.0",
    "eslint": "^9.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.8.3"
  }
}